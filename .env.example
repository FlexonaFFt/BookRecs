# =============================================================================
# BookRecs — Environment Configuration
# =============================================================================
# Скопируй этот файл в .env и заполни значения под свой режим запуска.
# НИКОГДА не коммить .env с реальными секретами!
#
# РЕЖИМЫ ЗАПУСКА:
#
#   Локальная разработка (Postgres + S3 в Docker):
#     COMPOSE_PROFILES=local-db,local-s3
#     BOOKRECS_PG_DSN=postgresql://bookrecs:change_me@postgres:5432/bookrecs
#     BOOKRECS_S3_ENDPOINT=http://minio:9000
#
#   Прод (внешний Postgres + внешний S3, например рег.ру):
#     COMPOSE_PROFILES=           ← пусто, контейнеры БД и S3 не запускаются
#     BOOKRECS_PG_DSN=postgresql://USER:PASSWORD@HOST:5432/DB
#     BOOKRECS_S3_ENDPOINT=https://s3.regru.cloud   ← или другой endpoint
# =============================================================================


# -----------------------------------------------------------------------------
# Docker Compose profiles
# -----------------------------------------------------------------------------
# local-db   → поднимает локальный postgres-контейнер
# local-s3   → поднимает локальный MinIO-контейнер
# (пусто)    → ничего локального не запускается, используются внешние сервисы
COMPOSE_PROFILES=local-db,local-s3


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Локальный контейнер (используется только при COMPOSE_PROFILES=local-db)
POSTGRES_USER=bookrecs
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=bookrecs

# DSN подключения — меняй под свой режим:
#
#   Локальная разработка:
BOOKRECS_PG_DSN=postgresql://bookrecs:change_me_postgres@postgres:5432/bookrecs
#
#   Прод (рег.ру Managed Postgres или VPS):
# BOOKRECS_PG_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

BOOKRECS_PG_MIGRATION_PATH=source/infrastructure/storage/postgres/migrations
BOOKRECS_RUN_MIGRATE=true


# -----------------------------------------------------------------------------
# S3 / MinIO
# -----------------------------------------------------------------------------

# Бэкенды:
#   BOOKRECS_STORE_BACKEND    = local | s3
#   BOOKRECS_REGISTRY_BACKEND = memory | postgres
BOOKRECS_STORE_BACKEND=s3
BOOKRECS_REGISTRY_BACKEND=postgres

BOOKRECS_S3_BUCKET=bookrecs
BOOKRECS_S3_REGION=ru-1
BOOKRECS_S3_PREFIX=s3://bookrecs/datasets/goodreads_ya

# Endpoint:
#   Локальная разработка (MinIO):
BOOKRECS_S3_ENDPOINT=http://minio:9000
#
#   Прод (рег.ру S3):
# BOOKRECS_S3_ENDPOINT=https://s3.regru.cloud
#
#   AWS S3 (оставь пустым):
# BOOKRECS_S3_ENDPOINT=

# Credentials для S3 / MinIO
AWS_ACCESS_KEY_ID=change_me_access_key
AWS_SECRET_ACCESS_KEY=change_me_secret_key
AWS_DEFAULT_REGION=ru-1

# MinIO root credentials (только для локального контейнера)
MINIO_ROOT_USER=change_me_access_key
MINIO_ROOT_PASSWORD=change_me_secret_key


# -----------------------------------------------------------------------------
# Dataset & raw data
# -----------------------------------------------------------------------------
BOOKRECS_DATASET_NAME=goodreads_ya
BOOKRECS_RAW_DIR=data/raw_data
BOOKRECS_BOOKS_RAW_URI=data/raw_data/books.json.gz
BOOKRECS_INTERACTIONS_RAW_URI=data/raw_data/interactions.json.gz


# -----------------------------------------------------------------------------
# Preprocessing params
# -----------------------------------------------------------------------------
BOOKRECS_K_CORE=2
BOOKRECS_KEEP_RECENT_FRACTION=0.6
BOOKRECS_TEST_FRACTION=0.25
BOOKRECS_LOCAL_VAL_FRACTION=0.2
BOOKRECS_WARM_USERS_ONLY=true
BOOKRECS_LANGUAGE_FILTER_ENABLED=true
BOOKRECS_INTERACTIONS_CHUNKSIZE=200000


# -----------------------------------------------------------------------------
# Pipeline orchestration
# -----------------------------------------------------------------------------
BOOKRECS_SKIP_PREPARE=false
BOOKRECS_SKIP_TRAIN=false

# Promotion quality gates (оставь пустым чтобы отключить порог)
BOOKRECS_PROMOTION_REQUIRE_SUCCESS=true
BOOKRECS_PROMOTION_MIN_NDCG10=
BOOKRECS_PROMOTION_MIN_RECALL10=
BOOKRECS_PROMOTION_MIN_COLD_NDCG10=
BOOKRECS_PROMOTION_MIN_COLD_RECALL10=


# -----------------------------------------------------------------------------
# Training settings
# -----------------------------------------------------------------------------

# Профиль ресурсов: auto | default | lite
BOOKRECS_TRAIN_PROFILE=auto
BOOKRECS_TRAIN_AUTO_TUNE=false

BOOKRECS_TRAIN_DATASET_DIR=artifacts/tmp_preprocessed/goodreads_ya
BOOKRECS_TRAIN_OUTPUT_ROOT=artifacts/runs
BOOKRECS_TRAIN_RUN_NAME=

BOOKRECS_TRAIN_EVAL_USERS_LIMIT=2000
BOOKRECS_COLD_MAX_INTERACTIONS=5

BOOKRECS_TRAIN_CANDIDATE_POOL_SIZE=1000
BOOKRECS_TRAIN_PER_SOURCE_LIMIT=300
BOOKRECS_TRAIN_PRE_TOP_M=300
BOOKRECS_TRAIN_FINAL_TOP_K=10

BOOKRECS_TRAIN_CF_MODE=auto
BOOKRECS_TRAIN_CF_MAX_NEIGHBORS=120
BOOKRECS_TRAIN_CF_MAX_ITEMS_PER_USER=150
BOOKRECS_TRAIN_CONTENT_MAX_NEIGHBORS=120

BOOKRECS_TRAIN_PRERANK_MODEL=auto
BOOKRECS_TRAIN_CATBOOST_ITERATIONS=250
BOOKRECS_TRAIN_CATBOOST_DEPTH=6
BOOKRECS_TRAIN_CATBOOST_LEARNING_RATE=0.08

BOOKRECS_TRAIN_SEED=42


# -----------------------------------------------------------------------------
# Inference API
# -----------------------------------------------------------------------------
BOOKRECS_API_HOST=0.0.0.0
BOOKRECS_API_PORT=8000

BOOKRECS_API_MODEL_URI=artifacts/baselines/testmodel/models
BOOKRECS_ACTIVE_MODEL_POINTER=artifacts/runs/active_model.json
BOOKRECS_API_MODEL_AUTO_RELOAD_SEC=60
BOOKRECS_API_MODEL_CACHE_DIR=artifacts/cache/models

BOOKRECS_API_HISTORY_TABLE=user_item_interactions
BOOKRECS_API_INFERENCE_LOG_TABLE=inference_requests


# -----------------------------------------------------------------------------
# Airflow / Batch orchestration
# -----------------------------------------------------------------------------

# Абсолютный путь к проекту на HOST-машине (для bind-маунтов в DockerOperator)
BOOKRECS_HOST_PROJECT_DIR=/home/ubuntu/bookrecs

BOOKRECS_BATCH_IMAGE=ghcr.io/flexonafft/bookrecs:latest
BOOKRECS_DOCKER_NETWORK=bookrecs_net

AIRFLOW_WEBSERVER_PORT=8080

# Учётная запись admin в Airflow UI — обязательно сменить!
AIRFLOW_ADMIN_USERNAME=change_me_airflow_user
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_password

# Метабаза Airflow (отдельная от основной БД приложения)
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change_me_airflow_pg
AIRFLOW_POSTGRES_DB=airflow

# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change_me_fernet_key

# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_webserver_secret
